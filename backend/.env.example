# -----------------------------------------------------------------------------
# BACKEND ENVIRONMENT VARIABLES (EXAMPLE)
# Copy this file to '.env' inside the backend/ directory (or root) and fill in the values.
# -----------------------------------------------------------------------------

# --- Spring Boot Server Port ---
# SERVER_PORT=8080

# --- Database configuration ---
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/shop_acc_game?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# --- Security & Auth (JWT) ---
JWT_SECRET=your_super_secure_jwt_secret_key_here

# --- Cloudflare R2 / AWS S3 Configuration ---
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_API_TOKEN=your_cloudflare_api_token
R2_BUCKET_NAME=your_cloudflare_bucket_name
R2_PUBLIC_URL=https://pub-331231a8c21d4e6db2f224146773362c.r2.dev

# --- PayOS configuration (VietQR Payments) ---
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

